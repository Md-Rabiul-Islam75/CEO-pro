# =============================================================================
# .env.example — template. Copy to .env and fill in real values.
# Every key here is commented out on purpose; this file is documentation only.
# =============================================================================

# PostgreSQL connection (Prisma) — full URL + schema provided later
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA_NAME"

# Firebase Storage (added later)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# FIREBASE_SERVICE_ACCOUNT_KEY=

# Database (individual parts)
# DB_HOST=your_database_host
# DB_PORT=5432
# DB_NAME=your_database_name
# DB_USER=your_database_user
# DB_PASSWORD=your_database_password
# DB_SCHEMA=your_database_schema

# Uploads / avatars
# AVATAR_MAX_SIZE=5242880
# AVATAR_ALLOWED_FORMATS=image/jpeg,image/png

# Misc
# USER_JOIN_DATE_FORMAT=yyyy-MM-dd
# GOOGLE_APPLICATION_CREDENTIALS=/app/firebase-service-account.json

# Firebase Storage bucket
# BUCKET_NAME=your_firebase_storage_bucket
# FIREBASE_URL=https://firebasestorage.googleapis.com/v0/b/

# App base URLs
# FRONTEND_BASE_URL=http://localhost:3000
# BACKEND_BASE_URL=http://localhost:8000

# Security / CORS
# COOKIE_SECURE=false
# CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT
# JWT_SECRET=replace_with_a_long_random_secret
# JWT_ACCESS_EXPIRATION=86400000
# JWT_REFRESH_EXPIRATION=604800000

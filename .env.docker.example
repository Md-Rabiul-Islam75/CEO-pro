# =============================================================================
# Runtime environment for the container (reference).
#
# docker-compose.yml already sets these for the BUNDLED Postgres, so you don't
# need this file for `docker compose up`. Use it when running the image on its
# own (e.g. `docker run --env-file .env.docker ...`) or when pointing at an
# EXTERNAL / managed Postgres.
# =============================================================================

NODE_ENV=production
PORT=8011

# --- Database: either the DB_* parts … -------------------------------------
DB_HOST=your-postgres-host
DB_PORT=5432
DB_NAME=ceo
DB_USER=ceo
DB_PASSWORD=change_me
DB_SCHEMA=ceo

# --- … or a single URL (takes precedence over the DB_* parts above) ---------
# DATABASE_URL=postgresql://user:pass@host:5432/ceo?schema=ceo
